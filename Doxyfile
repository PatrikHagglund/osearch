# Doxygen configuration for osearch — only settings that differ from the
# defaults; everything omitted takes Doxygen's default value.
# Regenerate this minimal form after edits with: doxygen -x Doxyfile
# Build the docs with: ninja -C build doc   (or: doxygen Doxyfile)

PROJECT_NAME           = osearch
INPUT                  = src

# Document everything, including file-static functions (most of osearch's
# internals are static), without requiring \brief markers.
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES

# Browsable source with call/caller graphs (needs graphviz).
SOURCE_BROWSER         = YES
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
