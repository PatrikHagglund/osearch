<?xml version="1.0"?>
<osearch_config>
  <description value="gcc 4.8" />
  <get_version value="gcc -dumpversion" />

  <prime command="gcc OSEARCH_OPTS -o OSEARCH_OUT OSEARCH_IN" />







  <flag type="simple" value="-O1" />
  <flag type="simple" value="-O2" />
  <flag type="simple" value="-O3" />
  <flag type="simple" value="-Os" />

  <!-- Default options (to be turned off) -->

  <flag type="simple" value="-falign-loops" />

  <flag type="simple" value="-fno-align-loops" />
  <flag type="simple" value="-fno-argument-alias" />
  <flag type="simple" value="-fno-asynchronous-unwind-tables" />
  <flag type="simple" value="-fno-auto-inc-dec" />
  <flag type="simple" value="-fno-branch-count-reg" />
  <flag type="simple" value="-fno-common" />
  <flag type="simple" value="-fno-early-inlining" />
  <flag type="simple" value="-fno-eliminate-unused-debug-types" />
  <flag type="simple" value="-fno-emit-class-debug-always" />
  <flag type="simple" value="-fno-function-cse" />
  <flag type="simple" value="-fno-gcse-lm" />
  <flag type="simple" value="-fno-ident" />
  <flag type="simple" value="-fno-inline-functions-called-once" />
  <flag type="simple" value="-fno-ivopts" />
  <flag type="simple" value="-fno-keep-static-consts" />
  <flag type="simple" value="-fno-leading-underscore" />
  <flag type="simple" value="-fno-move-loop-invariants" />
  <flag type="simple" value="-fno-peephole" />
  <flag type="simple" value="-fno-reg-struct-return" />
  <flag type="simple" value="-fno-sched-interblock" />
  <flag type="simple" value="-fno-sched-spec" />
  <flag type="simple" value="-fno-sched-stalled-insns-dep" />
  <flag type="simple" value="-fno-show-column" />
  <flag type="simple" value="-fno-split-ivs-in-unroller" />
  <flag type="simple" value="-fno-toplevel-reorder" />
  <flag type="simple" value="-fno-tree-loop-im" />
  <flag type="simple" value="-fno-tree-loop-ivcanon" />
  <flag type="simple" value="-fno-tree-loop-optimize" />
  <flag type="simple" value="-fno-tree-reassoc" />
  <flag type="simple" value="-fno-tree-scev-cprop" />
  <flag type="simple" value="-fno-tree-vect-loop-version" />
  <flag type="simple" value="-fno-zero-initialized-in-bss" />


  <!-- Tuning options that have a numeric value -->
  <flag type="tuning" value="-finline-limit" default="600" min="100" max="10000" step="200" separator="=" />


</osearch_config>
