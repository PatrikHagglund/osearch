<?xml version="1.0"?>
<osearch_config>
  <description value="gcc 16 (test)" />
  <get_version value="gcc -dumpversion" />

  <prime command="gcc OSEARCH_OPTS -o OSEARCH_OUT OSEARCH_IN" />

  <!-- Optimization level (mutually exclusive). Spans speed (-O3) and size
       (-Os) so this one config serves -p/time and -s; enum state 0 = -O0. -->
  <flag type="enum" value="-O3|-O2|-Os" />
  <flag type="simple" value="-ffast-math" />
  <flag type="simple" value="-march=native" />
  <flag type="simple" value="-flto" />
  <flag type="simple" value="-fno-inline-functions" />

  <!-- Key O2 flags (disable to test impact) -->
  <flag type="simple" value="-fno-cse-follow-jumps" />
  <flag type="simple" value="-fno-code-hoisting" />
  <flag type="simple" value="-fno-ipa-cp" />
  <flag type="simple" value="-fno-align-functions" />
  <flag type="simple" value="-fno-inline-small-functions" />
  <flag type="simple" value="-fno-caller-saves" />
  <flag type="simple" value="-fno-expensive-optimizations" />
  <flag type="simple" value="-fno-align-loops" />
  <flag type="simple" value="-fno-gcse" />
  <flag type="simple" value="-fno-crossjumping" />
  <flag type="simple" value="-fno-devirtualize" />
  <flag type="simple" value="-fno-hoist-adjacent-loads" />
  <flag type="simple" value="-fno-indirect-inlining" />
  <flag type="simple" value="-fno-inline-functions-called-once" />
  <flag type="simple" value="-fno-ipa-icf" />
  <flag type="simple" value="-fno-ipa-sra" />
  <flag type="simple" value="-fno-ivopts" />
  <flag type="simple" value="-fno-lra-remat" />
  <flag type="simple" value="-fno-move-loop-invariants" />
  <flag type="simple" value="-fno-optimize-sibling-calls" />
  <flag type="simple" value="-fno-optimize-strlen" />
  <flag type="simple" value="-fno-partial-inlining" />
  <flag type="simple" value="-fno-peephole2" />
  <flag type="simple" value="-fno-reorder-blocks-and-partition" />
  <flag type="simple" value="-fno-reorder-functions" />
  <flag type="simple" value="-fno-schedule-insns2" />
  <flag type="simple" value="-fno-store-merging" />
  <flag type="simple" value="-fno-strict-aliasing" />
  <flag type="simple" value="-fno-tree-loop-distribute-patterns" />
  <flag type="simple" value="-fno-tree-loop-im" />
  <flag type="simple" value="-fno-tree-loop-optimize" />
  <flag type="simple" value="-fno-tree-loop-vectorize" />
  <flag type="simple" value="-fno-tree-pre" />
  <flag type="simple" value="-fno-tree-slp-vectorize" />
  <flag type="simple" value="-fno-tree-switch-conversion" />
  <flag type="simple" value="-fno-tree-tail-merge" />
  <flag type="simple" value="-fno-tree-vrp" />
  <flag type="simple" value="-fno-unroll-loops" />

  <!-- O3 flags (enable to test impact) -->
  <flag type="simple" value="-fgcse-after-reload" />
  <flag type="simple" value="-fipa-cp-clone" />
  <flag type="simple" value="-floop-interchange" />
  <flag type="simple" value="-floop-unroll-and-jam" />
  <flag type="simple" value="-fpeel-loops" />
  <flag type="simple" value="-fpredictive-commoning" />
  <flag type="simple" value="-fsplit-loops" />
  <flag type="simple" value="-fsplit-paths" />
  <flag type="simple" value="-ftree-loop-distribution" />
  <flag type="simple" value="-ftree-partial-pre" />
  <flag type="simple" value="-funswitch-loops" />

  <!-- Promoted from the full config (config/gcc16.osearch): flags that only
       won once the full flag set was searched. Kept here so this config
       reproduces the full-config results without needing to run it. -->
  <flag type="simple" value="-funroll-all-loops" />
  <flag type="simple" value="-ffp-contract=on" />
  <flag type="simple" value="-fno-if-conversion" />
  <flag type="simple" value="-fno-if-conversion2" />
  <flag type="simple" value="-fno-plt" />
  <flag type="simple" value="-fno-tree-coalesce-vars" />
  <flag type="simple" value="-fno-tree-dominator-opts" />
  <flag type="simple" value="-fno-tree-ch" />
  <flag type="simple" value="-finline-stringops" />
  <flag type="simple" value="-ftracer" />
  <flag type="simple" value="-frename-registers" />
  <flag type="simple" value="-flive-range-shrinkage" />
  <flag type="simple" value="-fno-cprop-registers" />
  <flag type="simple" value="-fno-forward-propagate" />
  <flag type="simple" value="-fno-guess-branch-probability" />
  <flag type="simple" value="-fno-sched-dep-count-heuristic" />
  <flag type="simple" value="-fno-dse" />
  <flag type="simple" value="-fno-tree-dce" />
  <flag type="simple" value="-fno-tree-sra" />
  <flag type="simple" value="-fno-thread-jumps" />
  <flag type="simple" value="-fno-early-inlining" />
  <flag type="simple" value="-freorder-blocks-algorithm=simple" />

  <!-- Round 2 promotions: full-config winners, mostly size (-s) and the
       linbench/huffbench -p gaps. -fno-tree-sink/-ter recur across -s. -->
  <flag type="simple" value="-fno-tree-sink" />
  <flag type="simple" value="-fno-tree-ter" />
  <flag type="simple" value="-fno-ssa-phiopt" />
  <flag type="simple" value="-fno-tree-ccp" />
  <flag type="simple" value="-fno-tree-forwprop" />
  <flag type="simple" value="-fno-tree-reassoc" />
  <flag type="simple" value="-fno-tree-fre" />
  <flag type="simple" value="-fno-tree-scev-cprop" />
  <flag type="simple" value="-fno-dce" />
  <flag type="simple" value="-fno-ree" />
  <flag type="simple" value="-fno-shrink-wrap" />
  <flag type="simple" value="-fno-shrink-wrap-separate" />
  <flag type="simple" value="-fno-omit-frame-pointer" />
  <flag type="simple" value="-fno-align-jumps" />
  <flag type="simple" value="-fno-gcse-after-reload" />
  <flag type="simple" value="-fno-ipa-modref" />
  <flag type="simple" value="-fno-ipa-ra" />
  <flag type="simple" value="-fno-ipa-bit-cp" />
  <flag type="simple" value="-fno-ira-share-spill-slots" />
  <flag type="simple" value="-fno-move-loop-stores" />
  <flag type="simple" value="-fira-region=all" />
  <flag type="simple" value="-fschedule-insns" />
  <flag type="simple" value="-fgraphite" />

  <!-- Granular FP relaxations: help -s by dropping math error/exception
       paths without full -ffast-math (which can bloat via vectorization). -->
  <flag type="simple" value="-fno-math-errno" />
  <flag type="simple" value="-ffinite-math-only" />
  <flag type="simple" value="-fno-trapping-math" />

  <!-- Other useful flags -->
  <flag type="simple" value="-fno-asynchronous-unwind-tables" />
  <flag type="simple" value="-fno-common" />
  <flag type="simple" value="-fno-toplevel-reorder" />

</osearch_config>
